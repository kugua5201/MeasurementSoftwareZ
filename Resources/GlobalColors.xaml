<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 应用主题色 ===== -->
    <SolidColorBrush x:Key="MainPrimaryColor"    Color="#3F51B5"/>
    <SolidColorBrush x:Key="AccentColor"          Color="#FF4081"/>
    <SolidColorBrush x:Key="MainBackgroundColor"  Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SidebarColor"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryColor"     Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondaryColor"   Color="#757575"/>
    <SolidColorBrush x:Key="RightColor"           Color="White"/>
    <SolidColorBrush x:Key="BackgroundColor"      Color="White"/>

    <!-- ===== 状态语义色 ===== -->
    <!-- 成功 / 在线 / 已连接 -->
    <Color x:Key="StatusSuccessColor">#4CAF50</Color>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource StatusSuccessColor}"/>
    <SolidColorBrush x:Key="StatusSuccessBgBrush" Color="#E8F5E9"/>

    <!-- 错误 / 离线 / 失败 -->
    <Color x:Key="StatusErrorColor">#F44336</Color>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusErrorColor}"/>
    <SolidColorBrush x:Key="StatusErrorBgBrush" Color="#FFEBEE"/>

    <!-- 警告 -->
    <Color x:Key="StatusWarningColor">#FF9800</Color>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarningColor}"/>
    <SolidColorBrush x:Key="StatusWarningBgBrush" Color="#FFF3E0"/>

    <!-- 信息 / 蓝色 -->
    <Color x:Key="StatusInfoColor">#2196F3</Color>
    <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource StatusInfoColor}"/>
    <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#E3F2FD"/>

    <!-- 调试 / 紫色 -->
    <SolidColorBrush x:Key="StatusDebugBrush" Color="#9C27B0"/>

    <!-- ===== 禁用 / 占位色 ===== -->
    <SolidColorBrush x:Key="DisabledTextBrush"   Color="#9E9E9E"/>
    <SolidColorBrush x:Key="DisabledIconBrush"    Color="#BDBDBD"/>
    <SolidColorBrush x:Key="PlaceholderTextBrush" Color="#666666"/>

    <!-- ===== 边框 / 分隔 ===== -->
    <SolidColorBrush x:Key="LightBorderBrush"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="LightBackgroundBrush"  Color="#F5F5F5"/>

    <!-- ===== 阴影效果 ===== -->
    <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="1" Direction="270" Opacity="0.2" Color="#000000"/>

</ResourceDictionary>
