<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 页面顶部工具栏 Border 样式 ===== -->
    <Style x:Key="PageToolbarBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="15,8"/>
    </Style>

    <!-- ===== 统一的「保存配方」按钮样式 ===== 
         用法：<Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveRecipeCommand}"/>
    -->
    <Style x:Key="SaveRecipeButton" TargetType="Button" BasedOn="{StaticResource ButtonWarning}">
        <Setter Property="Padding" Value="15,6"/>
        <Setter Property="ToolTip" Value="保存配方"/>
        <Setter Property="Content" Value="保存配方"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="保存配方" FontSize="13"/>
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 页面根容器样式（统一白色背景） ===== -->
    <Style x:Key="PageRootGrid" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
    </Style>

</ResourceDictionary>
