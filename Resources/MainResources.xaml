<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        主资源聚合文件 — 仅负责按顺序合并子字典。
        加载顺序很重要：后面的字典可以引用前面字典中的 StaticResource。

        Resources/
        ├── GlobalSizes.xaml          尺寸变量（FormInputWidth 等）
        ├── GlobalColors.xaml         颜色 / 阴影
        ├── GlobalConverters.xaml     值转换器
        ├── GlobalEnumSources.xaml    ObjectDataProvider 枚举数据源
        ├── PlcConfigTemplates.xaml   PLC 配置模板选择器
        └── MainResources.xaml        ← 本文件（聚合入口）
    -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="GlobalSizes.xaml"/>
        <ResourceDictionary Source="GlobalColors.xaml"/>
        <ResourceDictionary Source="GlobalConverters.xaml"/>
        <ResourceDictionary Source="GlobalEnumSources.xaml"/>
        <ResourceDictionary Source="PlcConfigTemplates.xaml"/>
        <ResourceDictionary Source="PageToolbarStyles.xaml"/>
        <ResourceDictionary Source="GlobalDataGrid.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
