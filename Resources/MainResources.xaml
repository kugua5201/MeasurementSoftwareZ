<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:local="clr-namespace:MeasurementSoftware"
   xmlns:converters="clr-namespace:MeasurementSoftware.Converters"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Colors -->
    <SolidColorBrush x:Key="MainPrimaryColor" Color="#3F51B5"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FF4081"/>
    <SolidColorBrush x:Key="MainBackgroundColor" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SidebarColor" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextPrimaryColor" Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondaryColor" Color="#757575"/>
    <SolidColorBrush x:Key="RightColor" Color="White"/>

    <!--阴影效果 -->
    <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="20" ShadowDepth="1" Direction="270" Opacity="0.2" Color="#000000"/>

    <!-- 转换器 -->
    <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
    <converters:Object2VisibilityConverter x:Key="Object2VisibilityConverter"/>
    <converters:Object2VisibilityReConverter x:Key="Object2VisibilityReConverter"/>
    <converters:DeviceIdToNameConverter x:Key="DeviceIdToNameConverter"/>
    <!-- PLC 配置模板选择器 -->
    <converters:PlcConfigTemplateSelector x:Key="PlcConfigTemplateSelector">
        <!-- 西门子 S7 配置模板 -->
        <converters:PlcConfigTemplateSelector.SiemensS7Template>
            <DataTemplate>
                <StackPanel>
                    <TextBlock Text="西门子 S7 通讯参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2196F3"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 地址：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="机架号：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Rack, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="槽号：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Slot, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </converters:PlcConfigTemplateSelector.SiemensS7Template>

        <!-- 三菱 MC 配置模板 -->
        <converters:PlcConfigTemplateSelector.MitsubishiMCTemplate>
            <DataTemplate>
                <StackPanel>
                    <TextBlock Text="三菱 MC 通讯参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#4CAF50"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 地址：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </converters:PlcConfigTemplateSelector.MitsubishiMCTemplate>

        <!-- Modbus TCP 配置模板 -->
        <converters:PlcConfigTemplateSelector.ModbusTCPTemplate>
            <DataTemplate>
                <StackPanel>
                    <TextBlock Text="Modbus TCP 通讯参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#FF9800"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 地址：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="从站地址：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SlaveAddress, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </converters:PlcConfigTemplateSelector.ModbusTCPTemplate>

        <!-- Modbus RTU 配置模板 -->
        <converters:PlcConfigTemplateSelector.ModbusRTUTemplate>
            <DataTemplate>
                <StackPanel>
                    <TextBlock Text="Modbus RTU 通讯参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#9C27B0"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="COM 口：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Text="{Binding ComPort, UpdateSourceTrigger=PropertyChanged}" 
                                  IsEditable="True" Padding="5" Margin="0,0,0,10">
                            <ComboBoxItem Content="COM1"/>
                            <ComboBoxItem Content="COM2"/>
                            <ComboBoxItem Content="COM3"/>
                            <ComboBoxItem Content="COM4"/>
                            <ComboBoxItem Content="COM5"/>
                            <ComboBoxItem Content="COM6"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}" 
                                  Padding="5" Margin="0,0,0,10">
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">9600</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">19200</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">38400</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">57600</sys:Int32>
                            <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">115200</sys:Int32>
                        </ComboBox>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="数据位：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DataBits, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="5" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="停止位：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" SelectedItem="{Binding StopBits, UpdateSourceTrigger=PropertyChanged}" 
                                  Padding="5" Margin="0,0,0,10">
                            <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib">1</sys:Double>
                            <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib">1.5</sys:Double>
                            <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib">2</sys:Double>
                        </ComboBox>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="校验位：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" Text="{Binding Parity, UpdateSourceTrigger=PropertyChanged}" 
                                  Padding="5" Margin="0,0,0,10">
                            <ComboBoxItem Content="None" IsSelected="True"/>
                            <ComboBoxItem Content="Odd"/>
                            <ComboBoxItem Content="Even"/>
                            <ComboBoxItem Content="Mark"/>
                            <ComboBoxItem Content="Space"/>
                        </ComboBox>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="从站地址：" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SlaveAddress, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </converters:PlcConfigTemplateSelector.ModbusRTUTemplate>
    </converters:PlcConfigTemplateSelector>

    <converters:EnabledChannelFilterConverter x:Key="EnabledChannelFilterConverter"/>
</ResourceDictionary>
