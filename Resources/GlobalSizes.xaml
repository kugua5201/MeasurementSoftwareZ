<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ===== 表单布局尺寸 ===== -->
	<!-- 输入控件统一宽度（TextBox / ComboBox / NumericUpDown） -->
	<sys:Double x:Key="FormInputWidth">200</sys:Double>
	<!-- 表单标签列宽度（普通） -->
	<sys:Double x:Key="FormLabelWidth">90</sys:Double>
	<!-- 表单标签列宽度（宽，如"连接超时(ms)："） -->
	<sys:Double x:Key="FormLabelWidthWide">110</sys:Double>
	<!-- 表单标签列宽度（窄，如"标准值:"） -->
	<sys:Double x:Key="FormLabelWidthNarrow">60</sys:Double>
	<!-- 数值输入控件宽度（紧凑场景） -->
	<sys:Double x:Key="FormNumericWidth">150</sys:Double>
	<!-- 按钮宽度 -->
	<sys:Double x:Key="FormButtonWidth">120</sys:Double>

	<!-- 兼容旧引用（等同于 FormInputWidth） -->
	<sys:Double x:Key="PlcFieldInputWidth">200</sys:Double>


	<GridLength x:Key="FormGridWidthWide">110</GridLength>
</ResourceDictionary>
