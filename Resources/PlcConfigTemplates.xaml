                <StackPanel>
                    <TextBlock Text="西门子 S7-1200 通讯参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>

                    <!-- 基本通讯参数 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IP 地址：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 hc:InfoElement.Placeholder="例如：192.168.0.1"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1"
                                          Value="{Binding Port}" Minimum="1" Maximum="65535"
                                          Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="机架号：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <hc:NumericUpDown Grid.Row="2" Grid.Column="1"
                                          Value="{Binding Rack}" Minimum="0" Maximum="15"
                                          Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="槽号：" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="3" Grid.Column="1"
                                          Value="{Binding Slot}" Minimum="0" Maximum="31"
                                          Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left"/>
                    </Grid>

                    <Separator Margin="0,5"/>

                    <!-- 双缓冲读取配置 -->
                    <TextBlock Text="双缓冲读取配置" FontSize="13" FontWeight="Bold" Margin="0,10,0,5" Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="交替检查缓存1/2的可读标志 → 整块读取DB → 按字段定义解析 → 复位可读标志" 
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="启用双缓冲读取：" VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding SiemensReadCache.IsEnabled}"
                                      Style="{StaticResource ToggleButtonSwitch}"
                                      HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- 缓存区 1 -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,8,0,0"
                            IsEnabled="{Binding SiemensReadCache.IsEnabled}">
                        <StackPanel>
                            <TextBlock Text="缓存区 1" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DB 块：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding SiemensReadCache.Cache1.DbBlock, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="例如：DB10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="可读标志地址：" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding SiemensReadCache.Cache1.ReadableFlagAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left"
                                         hc:InfoElement.Placeholder="例如：DB1.DBX0.0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 缓存区 2 -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,8,0,0"
                            IsEnabled="{Binding SiemensReadCache.IsEnabled}">
                        <StackPanel>
                            <TextBlock Text="缓存区 2" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DB 块：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding SiemensReadCache.Cache2.DbBlock, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="例如：DB11"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="可读标志地址：" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding SiemensReadCache.Cache2.ReadableFlagAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left"
                                         hc:InfoElement.Placeholder="例如：DB1.DBX0.1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 缓存数据结构定义 -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,8,0,0"
                            IsEnabled="{Binding SiemensReadCache.IsEnabled}">
                        <StackPanel>
                            <TextBlock Text="缓存数据结构定义（两个缓存共用）" FontSize="12" FontWeight="Bold" Margin="0,0,0,4" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text="每行一个字段，格式：字段名:数据类型[:字节序]，偏移自动计算" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="类型：Bool, Byte, Int16, UInt16, Int32, UInt32, Float, Double, String  字节序：ABCD, BADC, CDAB, DCBA" 
                                       FontSize="10" Foreground="{DynamicResource ThirdTextBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBox Text="{Binding SiemensReadCache.StructureDefinitionText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxExtend}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80" MaxHeight="180"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     hc:InfoElement.Placeholder="时间戳:Double:DCBA&#x0a;测量值1:Float:DCBA&#x0a;测量值2:Float:DCBA"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="数据组数：" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <hc:NumericUpDown Value="{Binding SiemensReadCache.GroupCount}" Minimum="1" Maximum="100"
                                                      Width="120" HorizontalAlignment="Left"/>
                                    <TextBlock Text="（一个缓存块中重复结构的组数）" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" 
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Command="{Binding DataContext.ApplyCachePointsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Content="验证并应用" Style="{StaticResource ButtonPrimary}"
                                        Padding="12,4" Margin="0,0,8,0"/>
                                <!--<TextBlock VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Visibility="{Binding IsCacheReading, Converter={StaticResource Boolean2VisibilityConverter}}"
                                           Text="● 缓存读取中"/>-->
                            </StackPanel>
                            <TextBlock Text="{Binding SiemensReadCache.StructureValidationMessage}" FontSize="12" Margin="0,4,0,0"/>

                            <!-- 已验证字段预览（双击定位到对应点位） -->
                            <DataGrid x:Name="CacheFieldGrid1200"
                                      ItemsSource="{Binding SiemensReadCache.ExpandedFieldDefinitions}"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" SelectionMode="Single"
                                      HeadersVisibility="Column" RowHeight="28"
                                      MinHeight="50" MaxHeight="300" FontSize="12"
                                      Background="White" Margin="0,8,0,0"
                                      Visibility="{Binding SiemensReadCache.IsStructureValid, Converter={StaticResource Boolean2VisibilityConverter}}"
                                      BorderBrush="{DynamicResource BorderBrush}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDoubleClick">
                                        <i:InvokeCommandAction
                                            Command="{Binding DataContext.OpenCacheFieldPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding SelectedItem, ElementName=CacheFieldGrid1200}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="字段名" Binding="{Binding DisplayName}" Width="150"/>
                                    <DataGridTextColumn Header="类型" Binding="{Binding DataType}" Width="100"/>
                                    <DataGridTextColumn Header="字节序" Binding="{Binding ByteOrder}" Width="100"/>
                                    <DataGridTextColumn Header="缓存值" Binding="{Binding ParsedValue}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DataTemplate>
        </converters:PlcConfigTemplateSelector.SiemensS71200Template>

