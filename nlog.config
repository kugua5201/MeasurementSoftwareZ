<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<!--输出目标,往哪里输出-->
	<targets>
		<!--此部分中的所有目标将自动异步-->
		<default-wrapper xsi:type="AsyncWrapper"></default-wrapper>

		<target name="trace_file" xsi:type="File"
      fileName="${basedir}/Logs/Trace/trace_${shortdate}_001.txt"
      layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
      archiveFileName="${basedir}/Logs/Trace/trace_${shortdate}_{###}.txt"
      archiveAboveSize="1024000"
      maxArchiveFiles="100"
      archiveNumbering="Sequence"
      concurrentWrites="true"
      keepFileOpen="false" />

		<target name="debug_file" xsi:type="File"
      fileName="${basedir}/Logs/Debug/debug_${shortdate}_001.txt"
      layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
      archiveFileName="${basedir}/Logs/Debug/debug_${shortdate}_{###}.txt"
      archiveAboveSize="1024000"
      maxArchiveFiles="100"
      archiveNumbering="Sequence"
      concurrentWrites="true"
      keepFileOpen="false" />

		<target name="info_file" xsi:type="File"
      fileName="${basedir}/Logs/Info/info_${shortdate}_001.txt"
      layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
      archiveFileName="${basedir}/Logs/Info/info_${shortdate}_{###}.txt"
      archiveAboveSize="1024000"
      maxArchiveFiles="100"
      archiveNumbering="Sequence"
      concurrentWrites="true"
      keepFileOpen="false" />

		<target name="warn_file" xsi:type="File"
      fileName="${basedir}/Logs/Warn/warn_${shortdate}_001.txt"
      layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
      archiveFileName="${basedir}/Logs/Warn/warn_${shortdate}_{###}.txt"
      archiveAboveSize="1024000"
      maxArchiveFiles="100"
      archiveNumbering="Sequence"
      concurrentWrites="true"
      keepFileOpen="false" />

		<target name="error_file" xsi:type="File"
      fileName="${basedir}/Logs/Error/error_${shortdate}_001.txt"
      layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
      archiveFileName="${basedir}/Logs/Error/error_${shortdate}_{###}.txt"
      archiveAboveSize="1024000"
                maxArchiveFiles="100"
                archiveNumbering="Sequence"
                concurrentWrites="true"
                keepFileOpen="false" />

		<target name="fatal_file" xsi:type="File"
                fileName="${basedir}/Logs/Fatal/fatal_${shortdate}_001.txt"
                layout="${longdate} | ${event-properties:item=EventId_Id:whenEmpty=0} | ${uppercase:${level}} | ${logger} | ${message} ${exception:format=tostring}"
                archiveFileName="${basedir}/Logs/Fatal/fatal_${shortdate}_{###}.txt"
                archiveAboveSize="1024000"
                maxArchiveFiles="100"
                archiveNumbering="Sequence"
                concurrentWrites="true"
                keepFileOpen="false" />


		<target name="debugger" xsi:type="Debugger"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}|${exception} ${newline} ${stacktrace} ${newline}" />
	</targets>

	<!--规则配置-->
	<rules>
		<!-- 将 Trace 级别的日志输出到文件 -->
		<logger name="*" minlevel="Trace" maxlevel="Trace" writeTo="trace_file" />

		<!-- 将 Debug 级别的日志输出到文件和调试器 -->
		<logger name="*" minlevel="Debug" maxlevel="Debug" writeTo="debug_file,debugger" />

		<!-- 将 Info 级别的日志输出到文件 -->
		<logger name="*" minlevel="Info" maxlevel="Info" writeTo="info_file" />

		<!-- 将 Warn 级别的日志输出到文件 -->
		<logger name="*" minlevel="Warn" maxlevel="Warn" writeTo="warn_file" />

		<!-- 将 Error 级别的日志输出到文件 -->
		<logger name="*" minlevel="Error" maxlevel="Error" writeTo="error_file" />

		<!-- 将 Fatal 级别的日志输出到文件 -->
		<logger name="*" minlevel="Fatal" maxlevel="Fatal" writeTo="fatal_file" />
	</rules>
</nlog>