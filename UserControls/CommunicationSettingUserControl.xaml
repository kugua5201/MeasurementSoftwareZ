<UserControl x:Class="MeasurementSoftware.UserControls.CommunicationSettingUserControl"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:local="clr-namespace:MeasurementSoftware.UserControls"
		xmlns:hc="https://handyorg.github.io/handycontrol"
		x:Name="CommunicationSettingControl"
	 mc:Ignorable="d"
   d:DesignHeight="700" d:DesignWidth="1200">
	<hc:SimplePanel >
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- 操作按钮栏 -->
			<Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
				<StackPanel Orientation="Horizontal">
					<Button Command="{Binding AddDeviceCommand}" 
							Background="#2196F3" Foreground="White" 
							 Margin="0,0,10,0"
							ToolTip="添加设备">
						<StackPanel Orientation="Horizontal">
							<Path Fill="White" VerticalAlignment="Center" Margin="0,0,6,0"
								  Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
								  Width="16" Height="16" Stretch="Uniform"/>
							<TextBlock Text="添加设备" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Command="{Binding DeleteDeviceCommand}" 
							Background="#F44336" Foreground="White" 
							 Margin="0,0,10,0"
							ToolTip="删除选中设备">
						<StackPanel Orientation="Horizontal">
							<Path Fill="White" VerticalAlignment="Center" Margin="0,0,6,0"
								  Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
								  Width="16" Height="16" Stretch="Uniform"/>
							<TextBlock Text="删除设备" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Command="{Binding TestConnectionCommand}" 
							Background="#FF9800" Foreground="White" 
							 Margin="0,0,10,0"
							ToolTip="测试连接">
						<StackPanel Orientation="Horizontal">
							<Path Fill="White" VerticalAlignment="Center" Margin="0,0,6,0"
								  Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
								  Width="16" Height="16" Stretch="Uniform"/>
							<TextBlock Text="测试连接" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Command="{Binding SaveConfigurationCommand}" 
							Background="#4CAF50" Foreground="White" 
							 Margin="0,0,10,0"
							ToolTip="保存设备配置">
						<StackPanel Orientation="Horizontal">
							<Path Fill="White" VerticalAlignment="Center" Margin="0,0,6,0"
								  Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
								  Width="16" Height="16" Stretch="Uniform"/>
							<TextBlock Text="保存配置" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>
			</Border>

			<!-- 主内容区域 -->
			<Grid Grid.Row="1" Margin="15">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="300"/>
					<ColumnDefinition Width="15"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- 左侧：设备列表 -->
				<Border Grid.Column="0" Background="#f5f5f5" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
							<TextBlock Text="设备列表" FontSize="14" FontWeight="Bold"/>
						</Border>

						<ListBox Grid.Row="1" ItemsSource="{Binding Devices}" 
								 SelectedItem="{Binding SelectedDevice}"
								 BorderThickness="0"
								 Margin="5">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal">
										<!-- 图标颜色根据启用状态变化 -->
										<Path VerticalAlignment="Center" Margin="0,0,10,0"
											  Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z" 
											  Width="16" Height="16" Stretch="Uniform">
											<Path.Style>
												<Style TargetType="Path">
													<Setter Property="Fill" Value="#2196F3"/>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsEnabled}" Value="False">
															<Setter Property="Fill" Value="#BDBDBD"/>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Path.Style>
										</Path>
										<StackPanel>
											<!-- 设备名称样式根据启用状态变化 -->
											<TextBlock FontWeight="Bold">
												<TextBlock.Style>
													<Style TargetType="TextBlock">
														<Setter Property="Text" Value="{Binding DeviceName}"/>
														<Setter Property="Foreground" Value="#212121"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsEnabled}" Value="False">
																<Setter Property="Foreground" Value="#9E9E9E"/>
																<Setter Property="TextDecorations" Value="Strikethrough"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</TextBlock.Style>
											</TextBlock>
											<!-- 设备类型样式 -->
											<TextBlock FontSize="11">
												<TextBlock.Style>
													<Style TargetType="TextBlock">
														<Setter Property="Text" Value="{Binding DeviceType}"/>
														<Setter Property="Foreground" Value="#757575"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsEnabled}" Value="False">
																<Setter Property="Foreground" Value="#BDBDBD"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</TextBlock.Style>
											</TextBlock>
											<!-- 启用状态标签 -->
											<TextBlock FontSize="10" Margin="0,2,0,0">
												<TextBlock.Style>
													<Style TargetType="TextBlock">
														<Setter Property="Text" Value="✓ 已启用"/>
														<Setter Property="Foreground" Value="#4CAF50"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsEnabled}" Value="False">
																<Setter Property="Text" Value="✗ 已禁用"/>
																<Setter Property="Foreground" Value="#F44336"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</TextBlock.Style>
											</TextBlock>
										</StackPanel>
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
							<ListBox.ItemContainerStyle>
								<Style TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemBaseStyle}">
									<Setter Property="Padding" Value="10"/>
									<Setter Property="Margin" Value="2"/>
									<!-- 未启用的设备背景色变暗 -->
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsEnabled}" Value="False">
											<Setter Property="Background" Value="#F5F5F5"/>
											<Setter Property="Opacity" Value="0.7"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</ListBox.ItemContainerStyle>
						</ListBox>
					</Grid>
				</Border>

				<!-- 右侧：设备配置详情 -->
				<Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<!-- 当没有选中设备时显示提示 -->
						<Border Grid.Row="0" Grid.RowSpan="3" Background="White" 
								Visibility="{Binding SelectedDevice, Converter={StaticResource Object2VisibilityReConverter}}">
							<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
								<Path Fill="#E0E0E0" 
									  Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z" 
									  Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,20"/>
								<TextBlock Text="请先添加设备" 
										   FontSize="16" 
										   Foreground="#999" 
										   HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>

						<!-- 当有选中设备时显示配置 -->
						<Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
								Visibility="{Binding SelectedDevice, Converter={StaticResource Object2VisibilityConverter}}">
							<Grid>
								<TextBlock Text="设备配置" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
								<Button HorizontalAlignment="Right" 
										Command="{Binding OpenPointSettingCommand}"
										Background="#9C27B0" Foreground="White" 
										Padding="10,5"
										ToolTip="配置数据点位">
									<StackPanel Orientation="Horizontal">
										<Path Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"
											  Data="M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,12.5A1.5,1.5 0 0,1 10.5,11A1.5,1.5 0 0,1 12,9.5A1.5,1.5 0 0,1 13.5,11A1.5,1.5 0 0,1 12,12.5M12,7.2C9.9,7.2 8.2,8.9 8.2,11C8.2,14 12,17.5 12,17.5C12,17.5 15.8,14 15.8,11C15.8,8.9 14.1,7.2 12,7.2Z" 
											  Width="14" Height="14" Stretch="Uniform"/>
										<TextBlock Text="配置点位" VerticalAlignment="Center"/>
									</StackPanel>
								</Button>
							</Grid>
						</Border>

						<!-- 设备配置表单 -->
						<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
									  Visibility="{Binding SelectedDevice, Converter={StaticResource Object2VisibilityConverter}}">
							<StackPanel Margin="20" DataContext="{Binding SelectedDevice}">
								<!-- 基本信息 -->
								<TextBlock Text="基本信息" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2196F3"/>

								<Grid Margin="0,0,0,15">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="100"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>

									<TextBlock Grid.Row="0" Grid.Column="0" Text="设备ID：" VerticalAlignment="Center" Margin="0,0,0,10"/>
									<TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DeviceId}" 
											 IsReadOnly="True" Background="#F5F5F5"
											 Padding="5" Margin="0,0,0,10"/>

									<TextBlock Grid.Row="1" Grid.Column="0" Text="设备名称：" VerticalAlignment="Center" Margin="0,0,0,10"/>
									<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}" 
											 Padding="5" Margin="0,0,0,10"/>

									<TextBlock Grid.Row="2" Grid.Column="0" Text="设备类型：" VerticalAlignment="Center" Margin="0,0,0,10"/>
									<ComboBox Grid.Row="2" Grid.Column="1" 
											  ItemsSource="{Binding DataContext.DeviceTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
											  SelectedItem="{Binding DeviceType}"
											  Padding="5" Margin="0,0,0,10"/>

									<TextBlock Grid.Row="3" Grid.Column="0" Text="启用：" VerticalAlignment="Center"/>
									<CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
								</Grid>

								<Separator Margin="0,10"/>

								<!-- 动态加载不同PLC类型的配置界面 -->
								<ContentControl Content="{Binding}" 
												ContentTemplateSelector="{StaticResource PlcConfigTemplateSelector}"
												Margin="0,15,0,0"/>
							</StackPanel>
						</ScrollViewer>

						<!-- 点位统计信息 -->
						<Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
								Visibility="{Binding SelectedDevice, Converter={StaticResource Object2VisibilityConverter}}">
							<Grid DataContext="{Binding SelectedDevice}">
								<StackPanel Orientation="Horizontal">
									<Path Fill="#FF9800" VerticalAlignment="Center" Margin="0,0,8,0"
										  Data="M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" 
										  Width="14" Height="14" Stretch="Uniform"/>
									<TextBlock FontSize="12" Foreground="#666">
										<Run Text="已配置"/>
										<Run Text="{Binding DataPoints.Count, Mode=OneWay}" FontWeight="Bold" Foreground="#2196F3"/>
										<Run Text="个数据点位"/>
									</TextBlock>
								</StackPanel>
							</Grid>
						</Border>
					</Grid>
				</Border>
			</Grid>
		</Grid>

		<!-- 右侧抽屉：点位设置 -->
		<hc:Drawer 
				   Dock="Right" 
				   ShowMode="Cover"
				   IsOpen="{Binding IsPointSettingOpen, Mode=TwoWay}">
			<Border Background="{DynamicResource RegionBrush}" 
					MinWidth="800" MaxWidth="900" 
					BorderThickness="1,0,0,0" 
					BorderBrush="#E0E0E0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- 抽屉标题栏 -->
					<Border Grid.Row="0" Background="#2196F3" Padding="15,12">
						<Grid>
							<StackPanel Orientation="Horizontal">
								
								<StackPanel>
									<TextBlock Text="数据点位配置" 
											   FontSize="16" 
											   FontWeight="Bold" 
											   Foreground="White"/>
									<TextBlock Text="{Binding SelectedDevice.DeviceName, StringFormat='设备: {0}'}" 
											   FontSize="12" 
											   Foreground="#E3F2FD" 
											   Margin="0,2,0,0"/>
								</StackPanel>
							</StackPanel>
							<Button Command="hc:ControlCommands.Close" 
									HorizontalAlignment="Right" 
									Foreground="White" 
									Style="{StaticResource ButtonIcon}" 
									hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"/>
						</Grid>
					</Border>

					<!-- 点位操作工具栏 -->
					<Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
						<StackPanel Orientation="Horizontal">
							<Button Command="{Binding AddDataPointCommand}" 
									Background="#2196F3" Foreground="White" 
									Padding="10,6" Margin="0,0,8,0"
									ToolTip="添加数据点">
								<StackPanel Orientation="Horizontal">
									<Path Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"
										  Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
										  Width="14" Height="14" Stretch="Uniform"/>
									<TextBlock Text="添加点位" VerticalAlignment="Center" FontSize="12"/>
								</StackPanel>
							</Button>
                            <Button Command="{Binding DeleteDataPointCommand}" 
									Background="#F44336" Foreground="White" 
									Padding="10,6" Margin="0,0,8,0"
									ToolTip="删除选中点位">
								<StackPanel Orientation="Horizontal">
									<Path Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"
										  Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
										  Width="14" Height="14" Stretch="Uniform"/>
									<TextBlock Text="删除点位" VerticalAlignment="Center" FontSize="12"/>
								</StackPanel>
							</Button>
							<Button Command="{Binding SavePointConfigurationCommand}" 
									Background="#4CAF50" Foreground="White" 
									Padding="10,6"
									ToolTip="保存点位配置">
								<StackPanel Orientation="Horizontal">
									<Path Fill="White" VerticalAlignment="Center" Margin="0,0,5,0"
										  Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
										  Width="14" Height="14" Stretch="Uniform"/>
									<TextBlock Text="保存配置" VerticalAlignment="Center" FontSize="12"/>
								</StackPanel>
							</Button>
						</StackPanel>
					</Border>

					<!-- 数据点列表 -->
					<DataGrid Grid.Row="2" 
							  ItemsSource="{Binding SelectedDevice.DataPoints}" 
							  SelectedItem="{Binding SelectedDataPoint}"
							  AutoGenerateColumns="False"
							  CanUserAddRows="False"
                              
							  SelectionMode="Single"
							
							  HeadersVisibility="Column"
							  RowHeight="35"
							  FontSize="13"
                                 BorderBrush="{DynamicResource BorderBrush}"
							  Margin="10">
                        
						<DataGrid.Columns>
							<DataGridTextColumn Header="点位ID" Binding="{Binding PointId}" Width="100" IsReadOnly="True"/>
							<DataGridTextColumn Header="点位名称" Binding="{Binding PointName}" Width="120"/>
							<DataGridTextColumn Header="点位描述" Binding="{Binding PointDescription}" Width="150"/>
							<DataGridTextColumn Header="数据地址" Binding="{Binding Address}" Width="100"/>
							<DataGridComboBoxColumn Header="数据类型" Width="80" SelectedItemBinding="{Binding DataType}">
								<DataGridComboBoxColumn.ElementStyle>
									<Style TargetType="ComboBox">
										<Setter Property="ItemsSource">
											<Setter.Value>
												<x:Array Type="System:String" xmlns:System="clr-namespace:System;assembly=mscorlib">
													<System:String>Float</System:String>
													<System:String>Int</System:String>
													<System:String>Bool</System:String>
													<System:String>String</System:String>
												</x:Array>
											</Setter.Value>
										</Setter>
									</Style>
								</DataGridComboBoxColumn.ElementStyle>
								<DataGridComboBoxColumn.EditingElementStyle>
									<Style TargetType="ComboBox">
										<Setter Property="ItemsSource">
											<Setter.Value>
												<x:Array Type="System:String" xmlns:System="clr-namespace:System;assembly=mscorlib">
													<System:String>Float</System:String>
													<System:String>Int</System:String>
													<System:String>Bool</System:String>
													<System:String>String</System:String>
												</x:Array>
											</Setter.Value>
										</Setter>
									</Style>
								</DataGridComboBoxColumn.EditingElementStyle>
							</DataGridComboBoxColumn>
							<DataGridTextColumn Header="当前值" Binding="{Binding CurrentValue}" Width="80" IsReadOnly="True"/>
							<DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</Border>
		</hc:Drawer>
	</hc:SimplePanel>
</UserControl>