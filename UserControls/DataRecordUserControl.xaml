<UserControl x:Class="MeasurementSoftware.UserControls.DataRecordUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->


		<!-- 查询条件 -->
		<Border Grid.Row="0" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
								Padding="15" CornerRadius="5" Margin="0,0,0,10">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
				<hc:ComboBox SelectedItem="{Binding SelectedQueryMode}" ItemsSource="{Binding QueryModes}"
												Width="{StaticResource FormButtonWidth}" Margin="5,0,15,0" hc:InfoElement.Placeholder="查询方式"/>

				<DatePicker SelectedDate="{Binding StartDate}" Width="{StaticResource FormButtonWidth}" Margin="5,0" hc:InfoElement.Placeholder="开始时间"/>

				<TextBlock Text="到" VerticalAlignment="Center" Margin="10,0"/>

				<DatePicker SelectedDate="{Binding EndDate}" Width="{StaticResource FormButtonWidth}" Margin="5,0"  hc:InfoElement.Placeholder="结束时间"/>

				<hc:TextBox hc:InfoElement.Placeholder="请输入二维码内容" Width="{StaticResource FormNumericWidth}" Margin="15,0"  Visibility="{Binding CodeTextbox}" />


				<Button Content="查询" Command="{Binding QueryCommand}"
						Style="{StaticResource ButtonPrimary}"
												Width="{StaticResource FormButtonWidth}" Margin="20,0,0,0"/>
				<Button Content="导出" Command="{Binding ExportCsvCommand}"
						Style="{StaticResource ButtonDefault}"
												Width="{StaticResource FormButtonWidth}" Margin="10,0,0,0"/>
			</StackPanel>
		</Border>

        <!-- 数据列表 -->
        <Border Grid.Row="1" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                Padding="10" CornerRadius="5">
            <DataGrid ItemsSource="{Binding Records}"
                         SelectedItem="{Binding SelectedRecord}"
                         AutoGenerateColumns="False" IsReadOnly="True" 
                         CanUserSortColumns="True" CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="测量时间" Binding="{Binding MeasurementTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                    <DataGridTextColumn Header="配方名称" Binding="{Binding RecipeName}" Width="150"/>
                    <DataGridTextColumn Header="二维码" Binding="{Binding Barcode}" Width="150"/>
                    <DataGridTemplateColumn Header="测量结果" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OverallResult}" 
                                              FontWeight="Bold"
                                              Foreground="{Binding OverallResult, Converter={StaticResource Result2ColorConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="工步" Binding="{Binding StepNumber, StringFormat='{}{0}/{1}'}" Width="60"/>
                    <DataGridTextColumn Header="操作员" Binding="{Binding OperatorName}" Width="100"/>
                    <DataGridTemplateColumn Header="MES上传" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MesUploadStatus}" 
                                              Foreground="{Binding MesUploadStatus, Converter={StaticResource Status2ColorConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*"/>
                </DataGrid.Columns>

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="查看详情" Command="{Binding ViewDetailsCommand}"/>
                        <Separator/>
                        <MenuItem Header="删除记录" Command="{Binding DeleteRecordCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>
