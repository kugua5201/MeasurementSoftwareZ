<UserControl x:Class="MeasurementSoftware.UserControls.ChannelSettingUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MeasurementSoftware.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:converters="clr-namespace:MeasurementSoftware.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             xmlns:helpers="clr-namespace:MeasurementSoftware.Helpers"
             x:Name="ChannelSettingControl">
    <UserControl.Resources>
        <helpers:BindingProxy x:Key="VmProxy" Data="{Binding}" />
    </UserControl.Resources>
    <hc:SimplePanel>
        <Grid Style="{StaticResource PageRootGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 主内容区域 -->
            <Grid x:Name="MainContentGrid" Grid.Row="0" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="250"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.2*" MinWidth="350"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：产品图片 + 标注 -->
                <Border x:Name="ImagePanel" Grid.Column="0" Background="{DynamicResource RegionBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 图片区标题栏 -->
                        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
                            <Grid>
                                <!--<TextBlock Text="产品图片 / 点位标注" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>-->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <!--<Button Command="{Binding ImportProductImageCommand}" 
                                            Content="导入图片"
                                            Style="{StaticResource ButtonPrimary}"
                                            Padding="12,5" Margin="0,0,8,0"/>-->
                                    <Button Command="{Binding DeleteAnnotationCommand}" 
                                            Content="删除标注"
                                            Style="{StaticResource ButtonDanger}"
                                            Padding="12,5" Margin="0,0,8,0"/>
                                    <hc:ContextMenuButton Content="更多 ▾"
                                            Style="{StaticResource ButtonInfo}"
                                            Padding="12,5" ToolTip="布局选项">
                                        <hc:ContextMenuButton.Menu>
                                            <ContextMenu>
                                                <MenuItem x:Name="LayoutMenuItem" Header="切换为垂直布局" Click="ToggleLayout_Click"/>
                                                <MenuItem Header="恢复默认布局" Click="RestoreDefaultLayout_Click"/>
                                            </ContextMenu>
                                        </hc:ContextMenuButton.Menu>
                                    </hc:ContextMenuButton>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 图片显示区（支持右键标注 + 标注可拖动） -->
                        <Grid Grid.Row="1" x:Name="ImageContainer" ClipToBounds="True">
                            <!-- 图片 + 同尺寸标注层叠加 -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="ProductImage"
                                       Source="{Binding ProductImagePath, Converter={StaticResource StringToImageSourceConverter}}"
                                       Stretch="Uniform"
                                       MouseRightButtonDown="ProductImage_MouseRightButtonDown">
                                    <Image.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="在此添加标注" Command="{Binding AddAnnotationAtPointCommand}"/>
                                            <MenuItem Header="导入图片" Command="{Binding ImportProductImageCommand}"/>
                                        </ContextMenu>
                                    </Image.ContextMenu>
                                </Image>

                                <!-- 标注点叠加层：可拖动 -->
                                <ItemsControl ItemsSource="{Binding Annotations}" IsHitTestVisible="True">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource RelativeToPixelConverter}">
                                                        <Binding Path="X"/>
                                                        <Binding Path="ActualWidth" ElementName="ProductImage"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Top">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource RelativeToPixelConverter}">
                                                        <Binding Path="Y"/>
                                                        <Binding Path="ActualHeight" ElementName="ProductImage"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <local:AnnotationMarkerControl 
                                                Recipe="{Binding DataContext.CurrentRecipe, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                ForceDefaultColor="True"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="Annotation_MouseLeftButtonDown"
                                                MouseMove="Annotation_MouseMove"
                                                MouseLeftButtonUp="Annotation_MouseLeftButtonUp"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- 无图片遮罩 -->
                            <Border Background="{StaticResource LightBackgroundBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProductImagePath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ProductImagePath}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="48" Foreground="{StaticResource DisabledIconBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="右键导入产品图片" FontSize="14" Foreground="{StaticResource DisabledTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="选中通道后右键图片可添加标注点" FontSize="11" Foreground="{StaticResource PlaceholderTextBrush}"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>

                                </StackPanel>

                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="导入图片" Command="{Binding ImportProductImageCommand}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 可拖动分割条 -->
                <GridSplitter x:Name="MainSplitter" Grid.Column="1" Width="6" 
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE"
                              ShowsPreview="True"
                              DragCompleted="Splitter_DragCompleted"/>

                <!-- 右侧：通道列表 -->
                <Border x:Name="ChannelListPanel" Grid.Column="2" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding AddChannelCommand}" 
                                        Content="添加通道"
                                        Style="{StaticResource ButtonPrimary}"
                                        Padding="12,5" Margin="0,0,8,0"
                                        ToolTip="添加通道"/>
                                    <Button Command="{Binding DeleteChannelCommand}" 
                                        Content="删除通道"
                                        Style="{StaticResource ButtonDanger}"
                                        Padding="12,5" Margin="0,0,8,0"
                                        ToolTip="删除选中通道"/>
                                    <Button Command="{Binding RenumberPointsCommand}" 
                                        Content="重新编号"
                                        Style="{StaticResource ButtonPrimary}"
                                        Padding="12,5"
                                        ToolTip="重新排序通道编号"/>
                                </StackPanel>
                                <Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveRecipeCommand}"/>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Channels}" 
                              SelectedItem="{Binding SelectedChannel}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              RowHeight="35"
                              FontSize="13"
                              Background="{StaticResource BackgroundColor}"
                              MouseDoubleClick="DataGrid_MouseDoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="添加通道" Command="{Binding AddChannelCommand}" />
                                    <MenuItem Header="删除通道" Command="{Binding DeleteChannelCommand}" />
                                    <MenuItem Header="重新编号" Command="{Binding RenumberPointsCommand}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="编号" Binding="{Binding ChannelNumber}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="通道名称" Binding="{Binding ChannelName}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="工步" Binding="{Binding StepNumber}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding ChannelType}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="PLC设备" Binding="{Binding PlcDeviceId, Converter={StaticResource DeviceIdToNameConverter}}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="数据点位" Binding="{Binding DataPointName}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="点位地址" Binding="{Binding DataSourceAddress}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="标准值" Binding="{Binding StandardValue}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="上公差" Binding="{Binding UpperTolerance}" Width="70" IsReadOnly="True"/>
                                <DataGridTextColumn Header="下公差" Binding="{Binding LowerTolerance}" Width="70" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="校准" Binding="{Binding RequiresCalibration}" Width="65" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 通道编辑抽屉 -->
            <hc:Drawer Dock="Right" 
                   ShowMode="Cover"
                   IsOpen="{Binding IsChannelEditorOpen, Mode=TwoWay}" Tag="drawer" >
                <Border Background="{DynamicResource RegionBrush}" 
                    MinWidth="600" MaxWidth="700" 
                    BorderThickness="1,0,0,0" 
                     DataContext="{Binding Data, Source={StaticResource VmProxy}}"
                    BorderBrush="{DynamicResource BorderBrush}"
                   >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 抽屉标题栏 -->
                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="15,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DrawerTitle}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                                <Button Command="hc:ControlCommands.Close" 
                                    HorizontalAlignment="Right" 
                                    Foreground="White" 
                                    Style="{StaticResource ButtonIcon}" 
                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"/>
                            </Grid>
                        </Border>

                        <!-- 通道编辑表单 -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="20">
                            <StackPanel>
                                <TextBlock Text="基本信息" FontSize="13" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryBrush}"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="通道编号：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.ChannelNumber}" 
                                         IsReadOnly="True" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="通道名称：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.ChannelName, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="请输入通道名称"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="通道说明：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.ChannelDescription, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="请输入通道说明"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="通道类型：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1"
                                          Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding ChannelTypes}"
                                          SelectedItem="{Binding EditingChannel.ChannelType}"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="启用：" VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Row="4" Grid.Column="1" 
                                              IsChecked="{Binding EditingChannel.IsEnabled}" 
                                              Style="{StaticResource ToggleButtonSwitch}" 
                                              HorizontalAlignment="Left"/>
                                </Grid>

                                <Separator Margin="0,5,0,15"/>

                                <TextBlock Text="工步配置" FontSize="13" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource WarningBrush}"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="工步编号：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <hc:NumericUpDown Grid.Row="0" Grid.Column="1"
                                                  Value="{Binding EditingChannel.StepNumber}"
                                                  Minimum="1" Maximum="{Binding CurrentRecipe.TotalSteps, FallbackValue=99}"
                                                  Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="工步名称：" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.StepName, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"
                                         hc:InfoElement.Placeholder="例如：第一步"/>
                                </Grid>

                                <Separator Margin="0,5,0,15"/>

                                <TextBlock Text="测量参数" FontSize="13" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryBrush}"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="标准值：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.StandardValue}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="上公差：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.UpperTolerance}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="下公差：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.LowerTolerance}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="单位：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" 
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding EditingChannel.Unit, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="例如：mm"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="采样数量：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <hc:NumericUpDown Grid.Row="4" Grid.Column="1" 
                                                  Value="{Binding EditingChannel.SampleCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                  Minimum="1" Maximum="10000"
                                                  Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="校准：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <ToggleButton Grid.Row="5" Grid.Column="1"
                                                  IsChecked="{Binding EditingChannel.RequiresCalibration, Mode=TwoWay}"
                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                  HorizontalAlignment="Left" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="小数位数：" VerticalAlignment="Center"/>
                                    <hc:NumericUpDown Grid.Row="6" Grid.Column="1" 
                                                  Value="{Binding EditingChannel.DecimalPlaces}" 
                                                  Minimum="0" Maximum="6"
                                                  Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Separator Margin="0,5,0,15"/>

                                <TextBlock Text="数据源配置" FontSize="13" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryBrush}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PLC设备：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                    <hc:ComboBox Grid.Row="0" Grid.Column="1"
                                          Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding AvailablePlcDevices}"
                                          SelectedValue="{Binding EditingChannel.PlcDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="DeviceId"
                                          DisplayMemberPath="DeviceName"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                          hc:InfoElement.Placeholder="选择设备"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="数据点位：" VerticalAlignment="Center"/>
                                    <hc:ComboBox Grid.Row="1" Grid.Column="1" 
                                          Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding EditingChannel.AvailableDataPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValue="{Binding EditingChannel.DataPointId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="PointId"
                                          DisplayMemberPath="PointName"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"
                                          hc:InfoElement.Placeholder="选择数据点">

                                    </hc:ComboBox>

                                    <!-- 使用缓存值开关：仅当选中的点位是缓存生成的时候显示 -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="使用缓存值：" VerticalAlignment="Center" Margin="0,8,0,0"
                                               Visibility="{Binding ShowCacheToggle, Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0"
                                                Visibility="{Binding ShowCacheToggle, Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <ToggleButton IsChecked="{Binding EditingChannel.UseCacheValue, Mode=TwoWay}"
                                                      Style="{StaticResource ToggleButtonSwitch}"
                                                      HorizontalAlignment="Left"/>
                                        <TextBlock Text="开启后测量使用缓存解析值，关闭使用寄存器实时值"
                                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- 底部操作按钮 -->
                        <Border Grid.Row="1" Background="{DynamicResource SecondaryRegionBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15,10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Command="{Binding CancelEditChannelCommand}" 
                                    Content="取消" 
                                    Style="{StaticResource ButtonDefault}" 
                                    Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0"/>
                                <Button Command="{Binding SaveChannelCommand}" 
                                    Content="保存" 
                                    Style="{StaticResource ButtonSuccess}" 
                                    Width="{StaticResource FormButtonWidth}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </hc:Drawer>

        </Grid>
    </hc:SimplePanel>
</UserControl>
