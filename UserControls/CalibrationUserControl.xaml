<UserControl x:Class="MeasurementSoftware.UserControls.CalibrationUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
            <Grid>

                <Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveCalibrationCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：通道列表 -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="6"
                    Effect="{StaticResource EffectShadow1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="{DynamicResource SecondaryRegionBrush}" 
                            Padding="12" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z" 
                                  Fill="{DynamicResource PrimaryBrush}" 
                                  Width="16" Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="测量通道" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Channels}" 
                             SelectedItem="{Binding SelectedChannel}"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="5"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" 
                                        Padding="8,10" 
                                        CornerRadius="4"
                                        Margin="0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid VerticalAlignment="Center" Margin="0,0,10,0" Width="24" Height="24">
                                            <Path Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z" 
                                                  Width="20" Height="20" Stretch="Uniform"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Setter Property="Fill" Value="{StaticResource StatusInfoBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequiresCalibration}" Value="False">
                                                                <Setter Property="Fill" Value="{StaticResource DisabledIconBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>

                                            <Ellipse Width="8" Height="8" 
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,-1,-1"
                                                     Stroke="White" StrokeThickness="1.5"
                                                     Fill="{Binding RequiresCalibration, Converter={StaticResource Boolean2ColorConverter}}"/>
                                        </Grid>

                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding ChannelName}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RequiresCalibration}" Value="False">
                                                                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="3" 
                                                        Padding="6,2" 
                                                        Margin="0,4,0,0"
                                                        HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource StatusSuccessBgBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RequiresCalibration}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource StatusErrorBgBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✓ 已启用"/>
                                                                <Setter Property="Foreground" Value="{StaticResource StatusSuccessBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RequiresCalibration}" Value="False">
                                                                        <Setter Property="Text" Value="✗ 已停止"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource StatusErrorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧：校准操作区 -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource RegionBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="6"
                    Effect="{StaticResource EffectShadow1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" 
                            Background="{DynamicResource SecondaryRegionBrush}" 
                            Padding="12" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                  Fill="{DynamicResource PrimaryBrush}" 
                                  Width="18" Height="18" 
                                  Stretch="Uniform" 
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="通道校准" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 内容区 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="15">
                            <!-- 通道信息 + 校准方式（紧凑一行） -->
                            <Border Background="{DynamicResource BackgroundColor}" Padding="10,8" CornerRadius="4" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="170"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!--<Path Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z"
                                              Fill="{DynamicResource PrimaryBrush}"
                                              Width="14" Height="14"
                                              Stretch="Uniform"
                                              Margin="0,0,6,0"
                                              VerticalAlignment="Center"/>-->
                                        <TextBlock Text="{Binding SelectedChannel.ChannelName, FallbackValue='--'}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="  " />
                                        <TextBlock Text="A=" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedChannel.CalibrationCoefficientA, StringFormat='{}{0:F4}', FallbackValue='--'}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="B=" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedChannel.CalibrationCoefficientB, StringFormat='{}{0:F4}', FallbackValue='--'}" FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding CalibrationModes}"
                                              SelectedItem="{Binding SelectedCalibrationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource ComboBoxExtend}"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumToDisplayTextConverter}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- 校准数据输入 -->
                            <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Background="{DynamicResource RegionBrush}"
                                    Visibility="{Binding IsSinglePointCalibration, Converter={StaticResource Boolean2VisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="标准值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <hc:NumericUpDown Value="{Binding SinglePointStandardValue}" Width="{StaticResource FormNumericWidth}" Margin="0,0,12,0" DecimalPlaces="3"/>
                                    <TextBlock Text="测量值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <hc:NumericUpDown Value="{Binding SinglePointMeasuredValue}" Width="{StaticResource FormNumericWidth}" Margin="0,0,12,0" DecimalPlaces="3"/>
                                    <Button Content="执行单点校准" Command="{Binding ExecuteSinglePointCalibrationCommand}"
                                           Style="{StaticResource ButtonWarning}" Width="120"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Background="{DynamicResource RegionBrush}"
                                    Visibility="{Binding IsLeastSquaresCalibration, Converter={StaticResource Boolean2VisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="标准值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <hc:NumericUpDown Value="{Binding LeastSquaresStandardValue}" Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0" DecimalPlaces="3"/>
                                        <TextBlock Text="测量值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <hc:NumericUpDown Value="{Binding LeastSquaresMeasuredValue}" Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0" DecimalPlaces="3"/>
                                        <Button Content="添加" Command="{Binding AddLeastSquaresCalibrationPointCommand}" Style="{StaticResource ButtonPrimary}" Width="60" Height="28"/>
                                        <Button Content="删除" Command="{Binding RemoveLeastSquaresCalibrationPointCommand}" CommandParameter="{Binding SelectedLeastSquaresCalibrationPoint}" Style="{StaticResource ButtonDanger}" Width="60" Height="28" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding LeastSquaresCalibrationPoints}"
                                             SelectedItem="{Binding SelectedLeastSquaresCalibrationPoint, Mode=TwoWay}"
                                             SelectionUnit="FullRow"
                                             AutoGenerateColumns="False" CanUserAddRows="False"
                                             HeadersVisibility="Column" Margin="0,0,0,8"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                             MinHeight="120" MaxHeight="250"
                                             Background="{StaticResource BackgroundColor}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="删除"
                                                          Command="{Binding RemoveLeastSquaresCalibrationPointCommand}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="标准值" Binding="{Binding StandardValue, StringFormat=F3}" Width="*"/>
                                            <DataGridTextColumn Header="测量值" Binding="{Binding MeasuredValue, StringFormat=F3}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Button Content="执行校准" Command="{Binding ExecuteLeastSquaresCalibrationCommand}" Style="{StaticResource ButtonWarning}" Width="100" Margin="0,0,8,0"/>
                                        <Button Content="清空" Command="{Binding ClearLeastSquaresCalibrationPointsCommand}" Style="{StaticResource ButtonDefault}" Width="60"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Background="{DynamicResource RegionBrush}"
                                    Visibility="{Binding IsLinearRegressionCalibration, Converter={StaticResource Boolean2VisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="标准值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <hc:NumericUpDown Value="{Binding LinearRegressionStandardValue}" Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0" DecimalPlaces="3"/>
                                        <TextBlock Text="测量值:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <hc:NumericUpDown Value="{Binding LinearRegressionMeasuredValue}" Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0" DecimalPlaces="3"/>
                                        <Button Content="添加" Command="{Binding AddLinearRegressionCalibrationPointCommand}" Style="{StaticResource ButtonPrimary}" Width="60" Height="28"/>
                                        <Button Content="删除" Command="{Binding RemoveLinearRegressionCalibrationPointCommand}" CommandParameter="{Binding SelectedLinearRegressionCalibrationPoint}" Style="{StaticResource ButtonDanger}" Width="60" Height="28" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding LinearRegressionCalibrationPoints}"
                                             SelectedItem="{Binding SelectedLinearRegressionCalibrationPoint, Mode=TwoWay}"
                                             SelectionUnit="FullRow"
                                             AutoGenerateColumns="False" CanUserAddRows="False"
                                             HeadersVisibility="Column" Margin="0,0,0,8"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                             MinHeight="120" MaxHeight="250"
                                             Background="{StaticResource BackgroundColor}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="删除"
                                                          Command="{Binding RemoveLinearRegressionCalibrationPointCommand}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="标准值" Binding="{Binding StandardValue, StringFormat=F3}" Width="*"/>
                                            <DataGridTextColumn Header="测量值" Binding="{Binding MeasuredValue, StringFormat=F3}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Button Content="执行校准" Command="{Binding ExecuteLinearRegressionCalibrationCommand}" Style="{StaticResource ButtonWarning}" Width="100" Margin="0,0,8,0"/>
                                        <Button Content="清空" Command="{Binding ClearLinearRegressionCalibrationPointsCommand}" Style="{StaticResource ButtonDefault}" Width="60"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Background="{DynamicResource RegionBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="校正历史" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CalibrationHistory.Count, StringFormat='({0}条)'}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        <Button Content="回用" Command="{Binding ApplySelectedCalibrationHistoryCommand}" Style="{StaticResource ButtonWarning}" Width="50" Height="24" FontSize="11" Margin="12,0,0,0"/>
                                        <Button Content="刷新" Command="{Binding RefreshCalibrationHistoryCommand}" Style="{StaticResource ButtonPrimary}" Width="50" Height="24" FontSize="11" Margin="8,0,0,0"/>
                                        <Button Content="删除" Command="{Binding RemoveSelectedCalibrationHistoryCommand}" Style="{StaticResource ButtonDanger}" Width="50" Height="24" FontSize="11" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding CalibrationHistory}"
                                             SelectedItem="{Binding SelectedCalibrationHistory, Mode=TwoWay}"
                                             SelectionUnit="FullRow"
                                             AutoGenerateColumns="False" IsReadOnly="True"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                             MinHeight="100" MaxHeight="350"
                                             Background="{StaticResource BackgroundColor}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="回用" Command="{Binding ApplySelectedCalibrationHistoryCommand}" />
                                                <MenuItem Header="删除" Command="{Binding RemoveSelectedCalibrationHistoryCommand}" />
                                                <MenuItem Header="刷新" Command="{Binding RefreshCalibrationHistoryCommand}" />
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="时间" Binding="{Binding CalibrationTime, StringFormat='yyyy-MM-dd HH:mm'}" Width="150"/>
                                            <DataGridTextColumn Header="方式" Binding="{Binding MethodName}" Width="90"/>
                                            <DataGridTextColumn Header="A" Binding="{Binding CoefficientA, StringFormat=F4}" Width="*"/>
                                            <DataGridTextColumn Header="B" Binding="{Binding CoefficientB, StringFormat=F4}" Width="*"/>
                                            <DataGridTextColumn Header="点数" Binding="{Binding CalibrationPoints.Count}" Width="50"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部操作按钮 -->
                </Grid>
            </Border>
        </Grid>
    </Grid>

</UserControl>
