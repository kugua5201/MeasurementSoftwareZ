<UserControl x:Class="MeasurementSoftware.UserControls.CalibrationUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
            <Grid>

                <Button Content="写入数据" Command="{Binding WriteCalibrationToPlcCommand}"
           Style="{StaticResource ButtonPrimary}"
           Width="{StaticResource FormButtonWidth}" Margin="0,0,10,0" HorizontalAlignment="Left"/>

                <Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveCalibrationCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：通道列表 -->
            <Border Grid.Column="0" 
                    Background="White" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="6"
                    Effect="{StaticResource EffectShadow1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="{DynamicResource SecondaryRegionBrush}" 
                            Padding="12" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20,18H4V6H20M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4Z" 
                                  Fill="{DynamicResource PrimaryBrush}" 
                                  Width="16" Height="16" 
                                  Stretch="Uniform" 
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="测量通道列表" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Channels}" 
                             SelectedItem="{Binding SelectedChannel}"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="5"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border
                                        BorderThickness="1"
                                        Padding="10" 
                                        CornerRadius="4"
                                        Margin="2,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                                 Fill="{Binding RequiresCalibration, Converter={StaticResource Boolean2ColorConverter}}"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ChannelName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding StepName, StringFormat='工步: {0}'}" 
                                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding RequiresCalibration, Converter={StaticResource Boolean2TextConverter}, ConverterParameter='需要校准|无需校准'}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{Binding RequiresCalibration, Converter={StaticResource Boolean2ColorConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧：校准操作区 -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource RegionBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="6"
                    Effect="{StaticResource EffectShadow1}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Border Grid.Row="0" 
                            Background="{DynamicResource SecondaryRegionBrush}" 
                            Padding="12" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="0,0,0,1"
                            CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                  Fill="{DynamicResource PrimaryBrush}" 
                                  Width="18" Height="18" 
                                  Stretch="Uniform" 
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="通道校准" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 内容区 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <!-- 通道信息 -->
                            <Border Background="{DynamicResource BackgroundColor}" Padding="15" CornerRadius="6" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="通道名称" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding SelectedChannel.ChannelName, FallbackValue='--'}" 
                                                  FontSize="14" FontWeight="Bold" Margin="0,3,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="标准值" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding SelectedChannel.StandardValue, StringFormat='{}{0:F3}', FallbackValue='--'}" 
                                                  FontSize="14" FontWeight="Bold" Margin="0,3,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="校准状态" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding CalibrationStatus}" 
                                                  FontSize="14" FontWeight="Bold" Margin="0,3,0,0"
                                                  Foreground="{Binding CalibrationStatusColor}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,0,0">
                                        <TextBlock Text="校准系数 A" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding SelectedChannel.CalibrationCoefficientA, StringFormat='{}{0:F6}', FallbackValue='--'}" 
                                                  FontSize="13" Margin="0,3,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,15,0,0">
                                        <TextBlock Text="校准系数 B" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding SelectedChannel.CalibrationCoefficientB, StringFormat='{}{0:F6}', FallbackValue='--'}" 
                                                  FontSize="13" Margin="0,3,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,15,0,0">
                                        <TextBlock Text="上次校准时间" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding SelectedChannel.LastCalibrationTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}', FallbackValue='未校准'}" 
                                                  FontSize="13" Margin="0,3,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 校准方式选择（下拉列表） -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="15" CornerRadius="6" Margin="0,0,0,15" Background="{DynamicResource RegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="校准方式" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="校准模式：" VerticalAlignment="Center" Width="{StaticResource FormLabelWidthNarrow}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <ComboBox ItemsSource="{Binding CalibrationModes}"
                                                  SelectedItem="{Binding SelectedCalibrationMode}"
                                                  Width="{StaticResource FormInputWidth}"
                                                  Style="{StaticResource ComboBoxExtend}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumToDisplayTextConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="适用于简单的零点偏移校准，只需测量一个标准点"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSinglePointCalibration}" Value="False">
                                                        <Setter Property="Text" Value="使用最小二乘法进行线性拟合，精度更高，建议至少3个标准点"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 校准数据输入 -->
                            <hc:TabControl Margin="0,0,0,10" Style="{StaticResource TabControlCapsuleSolid}" TabStripPlacement="Top" >
                                <!-- 单点校准 -->
                                <hc:TabItem Header="单点校准" Visibility="{Binding IsSinglePointCalibration, Converter={StaticResource Boolean2VisibilityConverter}}">
                                    <StackPanel Margin="15" HorizontalAlignment="Left">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{StaticResource FormGridWidthWide}"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="标准值：" VerticalAlignment="Center" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <hc:NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding SinglePointStandardValue}" 
                                                            Width="{StaticResource FormNumericWidth}" Margin="0,0,0,8" DecimalPlaces="3"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="测量值：" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SinglePointMeasuredValue}" 
                                                            Width="{StaticResource FormNumericWidth}" DecimalPlaces="3"/>
                                        </Grid>

                                        <Button Content="执行单点校准" Command="{Binding ExecuteSinglePointCalibrationCommand}"
                                               Style="{StaticResource ButtonWarning}"
                                               Width="{StaticResource FormNumericWidth}" HorizontalAlignment="Left" Margin="0,5,0,0"/>


                                    </StackPanel>
                                </hc:TabItem>

                                <!-- 多点校准 -->
                                <hc:TabItem Header="多点校准">
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,15">
                                            <TextBlock Text="标准值:" VerticalAlignment="Center" Width="{StaticResource FormLabelWidthNarrow}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <hc:NumericUpDown Value="{Binding MultiPointStandardValue}" 
                                                            Width="{StaticResource FormButtonWidth}" Margin="5,0" DecimalPlaces="3"/>
                                            <TextBlock Text="测量值:" VerticalAlignment="Center" Width="{StaticResource FormLabelWidthNarrow}" Margin="15,0,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <hc:NumericUpDown Value="{Binding MultiPointMeasuredValue}" 
                                                            Width="{StaticResource FormButtonWidth}" Margin="5,0" DecimalPlaces="3"/>
                                            <Button Content="添加点" Command="{Binding AddCalibrationPointCommand}"
                                                   Style="{StaticResource ButtonPrimary}"
                                                   Width="80" Margin="15,0,0,0" Height="30"/>
                                        </StackPanel>

                                        <DataGrid Grid.Row="1" ItemsSource="{Binding CalibrationPoints}"
                                                 AutoGenerateColumns="False" CanUserAddRows="False"
                                                 HeadersVisibility="Column" Margin="0,0,0,15"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 MinHeight="150" MaxHeight="300"
                                                 Background="{StaticResource BackgroundColor}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="标准值" Binding="{Binding StandardValue, StringFormat=F3}" Width="*"/>
                                                <DataGridTextColumn Header="测量值" Binding="{Binding MeasuredValue, StringFormat=F3}" Width="*"/>
                                                <DataGridTemplateColumn Header="操作" Width="80">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="删除" Command="{Binding DataContext.RemoveCalibrationPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                   CommandParameter="{Binding}" Style="{StaticResource ButtonDanger}" Width="60" Height="25" Padding="0"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="执行多点校准" Command="{Binding ExecuteMultiPointCalibrationCommand}"
                                                   Style="{StaticResource ButtonWarning}"
                                                   Width="{StaticResource FormNumericWidth}" Margin="0,0,10,0"/>
                                            <Button Content="清空列表" Command="{Binding ClearCalibrationPointsCommand}"
                                                   Style="{StaticResource ButtonDefault}"
                                                   Width="{StaticResource FormButtonWidth}"/>
                                        </StackPanel>
                                    </Grid>
                                </hc:TabItem>

                                <!-- 校准历史 -->
                                <hc:TabItem Header="校准历史">
                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0" ItemsSource="{Binding CalibrationHistory}"
                                                 AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,15"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 MinHeight="150" MaxHeight="300"
                                                   Background="{StaticResource BackgroundColor}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="校准时间" Binding="{Binding CalibrationTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                                                <DataGridTextColumn Header="系数 A" Binding="{Binding CoefficientA, StringFormat=F6}" Width="*"/>
                                                <DataGridTextColumn Header="系数 B" Binding="{Binding CoefficientB, StringFormat=F6}" Width="*"/>
                                                <DataGridTextColumn Header="操作员" Binding="{Binding OperatorName}" Width="100"/>
                                                <DataGridTextColumn Header="校准点数" Binding="{Binding CalibrationPoints.Count}" Width="80"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Button Grid.Row="1" Content="刷新历史" Command="{Binding RefreshCalibrationHistoryCommand}"
                                               Style="{StaticResource ButtonPrimary}"
                                               Width="{StaticResource FormButtonWidth}" Height="30" HorizontalAlignment="Right"/>
                                    </Grid>
                                </hc:TabItem>
                            </hc:TabControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 底部操作按钮 -->
                </Grid>
            </Border>
        </Grid>
    </Grid>

</UserControl>
