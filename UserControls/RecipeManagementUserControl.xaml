<UserControl x:Class="MeasurementSoftware.UserControls.RecipeManagementUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             d:DesignHeight="600" d:DesignWidth="900"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Style="{StaticResource PageRootGrid}"
		  IsEnabled="{Binding IsOpeningRecipe, Converter={StaticResource Boolean2BooleanReConverter}}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- 顶部工具栏 -->
		<Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
			<Grid>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

					<Button Command="{Binding CreateNewRecipeCommand}"
									Style="{StaticResource ButtonSuccess}"
									Padding="15,6" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
							<TextBlock Text="新建配方" FontSize="13"/>
						</StackPanel>
					</Button>
					<!--<Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveRecipeCommand}"  Margin="0,0,6,0"
				 IsEnabled="{Binding HasRecipe}"/>-->
					<Button Command="{Binding OpenRecipeCommand}"
									Style="{StaticResource ButtonPrimary}"
									Padding="15,6" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
							<TextBlock Text="打开配方" FontSize="13"/>
						</StackPanel>
					</Button>
					<Button Command="{Binding SaveAsRecipeCommand}"
									Style="{StaticResource ButtonDefault}"
									Padding="15,6" IsEnabled="{Binding HasRecipe}">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
							<TextBlock Text="另存配方" FontSize="13"/>
						</StackPanel>
					</Button>
				</StackPanel>

			</Grid>
		</Border>

		<!-- 配方信息 -->
		<Grid Grid.Row="1" Margin="15">
			<!-- 有配方时显示 -->
			<Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}"
							BorderThickness="1" CornerRadius="5" Padding="20,15" VerticalAlignment="Top"
							Visibility="{Binding HasRecipe, Converter={StaticResource Boolean2VisibilityConverter}}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="90"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0" Grid.Column="0" Text="配方名称：" VerticalAlignment="Center" Margin="0,0,10,8"/>
						<TextBox Grid.Row="0" Grid.Column="1"
										 Style="{StaticResource TextBoxExtend}"
										 Text="{Binding CurrentRecipe.RecipeName, UpdateSourceTrigger=PropertyChanged}"
										 Margin="0,0,0,8"
										 hc:InfoElement.Placeholder="请输入配方名称"/>

						<TextBlock Grid.Row="1" Grid.Column="0" Text="配方描述：" VerticalAlignment="Center" Margin="0,0,10,8"/>
						<TextBox Grid.Row="1" Grid.Column="1"
										 Style="{StaticResource TextBoxExtend}"
										 Text="{Binding CurrentRecipe.Description, UpdateSourceTrigger=PropertyChanged}"
										 Margin="0,0,0,8"
										 hc:InfoElement.Placeholder="请输入配方描述"/>
						<Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,5,0,12"/>

						<TextBlock Grid.Row="3" Grid.Column="0" Text="文件路径：" VerticalAlignment="Center" Margin="0,0,10,0"
											 Foreground="{DynamicResource SecondaryTextBrush}"/>
						<TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
											 Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Text" Value="{Binding CurrentRecipePath}"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding CurrentRecipePath}" Value="">
										<Setter Property="Text" Value="（尚未保存）"/>
										<Setter Property="Foreground" Value="#F44336"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
				</Grid>
			</Border>

			<!-- 无配方提示 -->
			<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
									Visibility="{Binding HasRecipe, Converter={StaticResource Boolean2VisibilityReConverter}}">
				<TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="48"
									 HorizontalAlignment="Center" Margin="0,0,0,15"
									 Foreground="{DynamicResource SecondaryTextBrush}" Opacity="0.4"/>
				<TextBlock Text="尚未打开配方" FontSize="18" HorizontalAlignment="Center"
									 Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>
				<TextBlock Text="请点击「新建」或「打开」开始" FontSize="13" HorizontalAlignment="Center"
									 Foreground="{DynamicResource SecondaryTextBrush}" Opacity="0.6"/>
			</StackPanel>
		</Grid>

		<Border Grid.RowSpan="2"
				Background="#66000000"
               Panel.ZIndex="999"
				Visibility="{Binding IsOpeningRecipe, Converter={StaticResource Boolean2VisibilityConverter}}">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<Border Background="{DynamicResource RegionBrush}" CornerRadius="12" Padding="28,24">
					<StackPanel HorizontalAlignment="Center">
						<hc:LoadingCircle Width="56" Height="56" Foreground="{DynamicResource PrimaryBrush}"/>
						<TextBlock Text="正在初始化..."
								   Margin="0,16,0,0"
								   FontSize="14"
								   HorizontalAlignment="Center"
								   Foreground="{DynamicResource PrimaryTextBrush}"/>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>
    </Grid>
</UserControl>
