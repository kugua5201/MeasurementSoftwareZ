<UserControl x:Class="MeasurementSoftware.UserControls.LogViewerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 第一行：日期选择和快捷按钮 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="日期：" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                    <DatePicker SelectedDate="{Binding SelectedDate}" 
                                Width="{StaticResource FormNumericWidth}" 
                                VerticalAlignment="Center"
                                Margin="0,0,20,0"/>

                    <TextBlock Text="级别：" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                    <ComboBox ItemsSource="{Binding LogLevels}" 
                              SelectedItem="{Binding SelectedLevel}" 
                              Style="{StaticResource ComboBoxExtend}"
                              Width="{StaticResource FormButtonWidth}" 
                              VerticalAlignment="Center"
                              Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding StatusMessage}" 
                               VerticalAlignment="Center" 
                               Foreground="{DynamicResource SecondaryTextBrush}" 
                               FontSize="12" 
                               Margin="0,0,20,0"/>

                    <Button Command="{Binding RefreshCommand}" 
                            Content="刷新"
                            Style="{StaticResource ButtonSuccess}" 
                            Padding="15,6" 
                            Margin="0,0,8,0"/>
                    <Button Command="{Binding ClearLogsCommand}"
                            Content="清空"
                            Style="{StaticResource ButtonDanger}" 
                            Padding="15,6"/>
                </StackPanel>

                <!-- 第二行：状态栏 -->
            </Grid>
        </Border>

        <!-- 日志列表 -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding DisplayedLogs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  RowHeight="32"
                  FontSize="12"
                  BorderBrush="{StaticResource LightBorderBrush}"
                  BorderThickness="0"
                  Background="White"
               
                  GridLinesVisibility="None">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PlaceholderTextBrush}"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}" Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                    <Setter Property="Foreground" Value="{StaticResource StatusErrorBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="WARN">
                                    <Setter Property="Foreground" Value="{StaticResource StatusWarningBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="INFO">
                                    <Setter Property="Foreground" Value="{StaticResource StatusInfoBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                    <Setter Property="Foreground" Value="{StaticResource StatusDebugBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!--<DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PlaceholderTextBrush}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>-->
                <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="NoWrap"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Message}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 分页控制（使用 HandyControl 分页） -->
        <Border Grid.Row="2" Background="{StaticResource LightBackgroundBrush}" BorderBrush="{StaticResource LightBorderBrush}" BorderThickness="0,1,0,0" Padding="15,10">
            <hc:Pagination 
                MaxPageCount="{Binding TotalPages}"
                PageIndex="{Binding CurrentPage, Mode=TwoWay}"
                DataCountPerPage="{Binding PageSize}"
                IsJumpEnabled="True"
                HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</UserControl>
