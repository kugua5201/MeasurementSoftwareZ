<UserControl x:Class="MeasurementSoftware.UserControls.QrCodeSettingUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MeasurementSoftware.UserControls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource RegionBrush}">
    <UserControl.Resources>
        <!-- 页面级资源仅保留全局未覆盖的项 -->
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Border Grid.Row="0" Style="{StaticResource PageToolbarBorder}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                <Button Style="{StaticResource SaveRecipeButton}" Command="{Binding SaveConfigurationCommand}"/>
            </Grid>
        </Border>

    <hc:ScrollViewer Grid.Row="1">
        <StackPanel  Margin="10" Orientation="Vertical">
                        <!-- 基本设置 -->
            <hc:Card BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Effect="{StaticResource EffectShadow2}">
                <hc:Card.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
              Fill="{DynamicResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="基本设置" Style="{StaticResource TextBlockDefault}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </hc:Card.Header>
                <StackPanel Orientation="Vertical" Margin="15">

                    <!-- 启用二维码 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="启用二维码：" Width="{StaticResource FormLabelWidth}" VerticalAlignment="Center"/>
                        <ToggleButton IsChecked="{Binding Config.IsEnabled,Mode=TwoWay}" Style="{StaticResource ToggleButtonSwitch}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding Config.IsEnabled, Converter={StaticResource Boolean2VisibilityConverter}}">
                        <TextBlock Text="必须扫码：" Width="{StaticResource FormLabelWidth}" VerticalAlignment="Center"/>
                        <ToggleButton IsChecked="{Binding Config.RequireQrCodeBeforeMeasurement, Mode=TwoWay}" Style="{StaticResource ToggleButtonSwitch}"/>
                        <TextBlock Text="启用后启动测量先清空数据并等待扫码，收到有效二维码后才开始通道采集"
                                   FontSize="11" Margin="10,0,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 数据源类型 -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding Config.IsEnabled, Converter={StaticResource Boolean2VisibilityConverter}}">
                        <TextBlock Text="数据源类型：" Width="{StaticResource FormLabelWidth}" VerticalAlignment="Center"/>
                        <ComboBox Width="{StaticResource FormInputWidth}" Style="{StaticResource ComboBoxExtend}"
                                  ItemsSource="{Binding SourceTypes}"
                                  SelectedItem="{Binding Config.SourceType}"
                                  hc:InfoElement.Placeholder="请选择二维码数据来源">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </hc:Card>

            <!-- 数据源配置 -->
            <hc:Card BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Effect="{StaticResource EffectShadow2}"
                     Visibility="{Binding Config.IsEnabled, Converter={StaticResource Boolean2VisibilityConverter}}">
                <hc:Card.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Path Data="M17,7H22V17H17V19A1,1 0 0,0 18,20H20V22H17.5C16.95,22 16,21.55 16,21C16,21.55 15.05,22 14.5,22H12V20H14A1,1 0 0,0 15,19V5A1,1 0 0,0 14,4H12V2H14.5C15.05,2 16,2.45 16,3C16,2.45 16.95,2 17.5,2H20V4H18A1,1 0 0,0 17,5V7M2,7H13V9H4V15H13V17H2V7M20,15V9H17V15H20Z" 
              Fill="{DynamicResource SuccessBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="数据源配置" Style="{StaticResource TextBlockDefault}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </hc:Card.Header>
                <StackPanel Orientation="Vertical" Margin="10">

                    <!-- 键盘输入配置 -->
                    <Border Visibility="{Binding IsKeyboardInputVisible, Converter={StaticResource Boolean2VisibilityConverter}}"
                            Background="{DynamicResource InfoBrush}" CornerRadius="4" Padding="10">
                        <StackPanel Orientation="Horizontal" >
                            <Path Data="M11,4H13V16L18.5,10.5L19.92,11.92L12,19.84L4.08,11.92L5.5,10.5L11,16V4Z" 
                                  Fill="White" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="键盘输入模式已启用" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                <TextBlock Text="支持USB扫码枪或键盘直接输入，焦点位于输入框时自动接收" 
                                           Foreground="White" FontSize="12" Opacity="0.9"/>
                            </StackPanel>
                         
                        </StackPanel>
                    </Border>

                    <!-- 串口通信配置 -->
                    <StackPanel Visibility="{Binding IsSerialPortVisible, Converter={StaticResource Boolean2VisibilityConverter}}"
                                Margin="5,10,5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- COM口 + 刷新 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="COM 口：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding AvailableComPorts}"
                                          SelectedItem="{Binding Config.SerialPortName, Mode=TwoWay}"
                                          IsEditable="False"
                                          Width="{StaticResource PlcFieldInputWidth}"
                                          hc:InfoElement.Placeholder="请选择串口"
                                          VerticalAlignment="Center"/>
                                <Button Command="{Binding RefreshComPortsCommand}"
                                        Style="{StaticResource ButtonDefault}"
                                        Width="30" Height="30" Padding="0" Margin="8,0,0,0"
                                        VerticalAlignment="Center" ToolTip="刷新串口列表" Cursor="Hand">
                                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                          Stretch="Uniform" Fill="{DynamicResource PrimaryTextBrush}" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>

                            <!-- 波特率 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding Source={StaticResource BaudRateValues}}"
                                      SelectedItem="{Binding Config.BaudRate, Mode=TwoWay}"
                                      Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- 数据位 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="数据位：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding Source={StaticResource DataBitsValues}}"
                                      SelectedItem="{Binding Config.DataBits, Mode=TwoWay}"
                                      Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- 停止位 -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="停止位：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="3" Grid.Column="1"
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding Source={StaticResource StopBitsValues}}"
                                      SelectedItem="{Binding Config.StopBits, Mode=TwoWay}"
                                      Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                            <!-- 校验位 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="校验位：" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding Source={StaticResource ParityValues}}"
                                      SelectedItem="{Binding Config.Parity, Mode=TwoWay}"
                                      Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                    <!-- 以太网通信配置 -->
                    <StackPanel Visibility="{Binding IsEthernetVisible, Converter={StaticResource Boolean2VisibilityConverter}}"
                                Margin="5,10,5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     Style="{StaticResource TextBoxExtend}"
                                     Text="{Binding Config.EthernetIp, UpdateSourceTrigger=PropertyChanged}"
                                     Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                     hc:InfoElement.Placeholder="例如：192.168.1.100"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口号：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" 
                                              Value="{Binding Config.EthernetPort}" 
                                              Minimum="1" Maximum="65535"
                                              Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="通信协议：" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" 
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding ProtocolList}" 
                                      SelectedItem="{Binding Config.EthernetProtocol}"
                                      Width="{StaticResource PlcFieldInputWidth}" HorizontalAlignment="Left"
                                      hc:InfoElement.Placeholder="选择协议类型"/>
                        </Grid>
                    </StackPanel>

                    <!-- PLC寄存器配置 -->
                    <StackPanel Visibility="{Binding IsPlcRegisterVisible, Converter={StaticResource Boolean2VisibilityConverter}}"
                                Margin="5,10,5,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PLC设备：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding PlcDevices}" 
                                      SelectedItem="{Binding Config.SelectedPlcDevice}"
                                      DisplayMemberPath="DeviceName"
                                      Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                      hc:InfoElement.Placeholder="选择已配置的PLC设备"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="点位地址：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" 
                                      Style="{StaticResource ComboBoxExtend}"
                                      ItemsSource="{Binding AvailablePoints}" 
                                      SelectedItem="{Binding Config.SelectedPoint}"
                                      DisplayMemberPath="PointName"
                                      Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                      hc:InfoElement.Placeholder="选择点位地址"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="读取长度：" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" 
                                              Value="{Binding Config.PlcReadLength}" 
                                              Minimum="1" Maximum="1000"
                                              Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                    
                </StackPanel>
            </hc:Card>

            <!-- 数据校验配置 -->
            <hc:Card BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Effect="{StaticResource EffectShadow2}"
                     Visibility="{Binding Config.IsEnabled, Converter={StaticResource Boolean2VisibilityConverter}}">
                <hc:Card.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Path Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" 
              Fill="{DynamicResource WarningBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="数据校验与提取配置" Style="{StaticResource TextBlockDefault}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </hc:Card.Header>
                <StackPanel Orientation="Vertical" Margin="15">

                    <!-- 校验规则 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 起始符 -->
                        <CheckBox Grid.Row="0" Grid.Column="0" Content="启用起始符校验"
                                  IsChecked="{Binding Config.EnableStartSymbol}" 
                                  VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding Config.StartSymbol, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding Config.EnableStartSymbol}"
                                 Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                  hc:InfoElement.Placeholder="例如：\r"/>

                        <!-- 结束符 -->
                        <CheckBox Grid.Row="1" Grid.Column="0" Content="启用结束符校验"
                                  IsChecked="{Binding Config.EnableEndSymbol}" 
                                  VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding Config.EndSymbol, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding Config.EnableEndSymbol}"
                                 Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                  hc:InfoElement.Placeholder="例如：\n"/>

                        <!-- 长度校验 -->
                        <CheckBox Grid.Row="2" Grid.Column="0" Content="启用长度校验"
                                  IsChecked="{Binding Config.EnableLengthCheck}" 
                                  VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="2" Grid.Column="1" 
                                          Value="{Binding Config.ExpectedLength}" 
                                          IsEnabled="{Binding Config.EnableLengthCheck}"
                                          Minimum="1" Maximum="1000"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"/>
                    </Grid>

                    <Separator Margin="0,5"/>

                    <!-- 数据提取 -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="起始位置索引：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <hc:NumericUpDown Grid.Row="0" Grid.Column="1" 
                                          Value="{Binding Config.QrCodeStartIndex}" 
                                          Minimum="0" Maximum="999"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="提取字符长度：" VerticalAlignment="Center"/>
                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1" 
                                          Value="{Binding Config.QrCodeLength}" 
                                          Minimum="1" Maximum="1000"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left"/>
                    </Grid>

                </StackPanel>
            </hc:Card>

            <!-- 批次流水号配置 -->
            <hc:Card BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Effect="{StaticResource EffectShadow2}"
                     Visibility="{Binding IsBatchModeVisible, Converter={StaticResource Boolean2VisibilityConverter}}">
                <hc:Card.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Path Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7M17,11H7V9H17V11M15,15H7V13H15V15Z" 
              Fill="{DynamicResource DangerBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="批次流水号配置" Style="{StaticResource TextBlockDefault}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </hc:Card.Header>
                <StackPanel Orientation="Vertical" Margin="15">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 流水号前缀 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="流水号前缀：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding Config.BatchPrefix, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 hc:InfoElement.Placeholder="例如：BATCH"/>

                        <!-- 日期格式 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="日期格式：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding Config.BatchDateFormat, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 hc:InfoElement.Placeholder="例如：yyyyMMdd"/>

                        <!-- 流水号位数 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="流水号位数：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <hc:NumericUpDown Grid.Row="2" Grid.Column="1" 
                                          Value="{Binding Config.BatchSerialDigits}" 
                                          Minimum="1" Maximum="10"
                                          Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                        <!-- 当前流水号 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="当前流水号：" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Grid.Row="3" Grid.Column="1" 
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                                CornerRadius="4" Padding="8,4" 
                                Background="{DynamicResource SecondaryRegionBrush}"
                                Width="{StaticResource FormInputWidth}" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Config.CurrentBatchSerial}"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                        </Border>

                        <!-- 生成示例 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="生成测试：" VerticalAlignment="Center"/>
                        <Button Grid.Row="4" Grid.Column="1" 
                                Content="生成示例" 
                                Command="{Binding GenerateBatchNumberCommand}"
                                Style="{StaticResource ButtonWarning}" 
                                Width="{StaticResource FormButtonWidth}" HorizontalAlignment="Left"/>
                    </Grid>

                </StackPanel>
            </hc:Card>

            <!-- 测试区域 -->
            <hc:Card BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Effect="{StaticResource EffectShadow2}">
                <hc:Card.Header>
                    <StackPanel Orientation="Horizontal" Margin="10,5">
                        <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,5V19H5V5H19M16.5,16.25L9,12.75V7.75L16.5,11.25V16.25Z" 
              Fill="{DynamicResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="测试与验证" Style="{StaticResource TextBlockDefault}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </hc:Card.Header>
                <StackPanel Orientation="Vertical" Margin="15">

                    <Border Background="{DynamicResource SecondaryRegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,10">
                        <TextBlock Text="{Binding ListenValidationStatus}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource StatusInfoBrush}"/>
                    </Border>

                    <!-- 测试数据输入 -->
                    <TextBox Text="{Binding Config.TestRawData, UpdateSourceTrigger=PropertyChanged}" 
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             Style="{StaticResource TextBoxExtend}"
                             IsEnabled="{Binding Config.IsEnabled}"
                             hc:InfoElement.Placeholder="在此输入测试数据..."/>

                    <!-- 操作与结果显示 -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="监听验证" Command="{Binding StartListenValidationCommand}"
                                IsEnabled="{Binding CanStartListenValidation}"
                                Style="{StaticResource ButtonPrimary}"
                                Padding="15,6" Margin="0,0,8,0"/>
                        <Button Content="停止监听" Command="{Binding StopListenValidationCommand}"
                                IsEnabled="{Binding CanStopListenValidation}"
                                Style="{StaticResource ButtonDanger}"
                                Padding="15,6" Margin="0,0,8,0"/>
                        <Button Content="测试提取" Command="{Binding TestExtractionCommand}" 
                                IsEnabled="{Binding Config.IsEnabled}"
                                Style="{StaticResource ButtonSuccess}" 
                                Padding="15,6" Margin="0,0,8,0"/>
                        <Button Content="清除" Command="{Binding ClearTestDataCommand}" 
                                IsEnabled="{Binding Config.IsEnabled}"
                                Style="{StaticResource ButtonDefault}" 
                                Padding="15,6"
                                ToolTip="清除测试数据"/>

                        <!-- 结果展示 -->
                        <Border Margin="15,0,0,0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}" >
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="结果：" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Config.TestExtractedQrCode}" 
                                           Visibility="{Binding Config.TestExtractedQrCode, Converter={StaticResource String2VisibilityConverter}}"
                                           Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold" 
                                           FontSize="15" Margin="5,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Config.TestValidationResult}" 
                                           FontSize="12" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="400"
                                            ToolTip="{Binding Config.TestValidationResult}">
                                     <TextBlock.Style>
                                         <Style TargetType="TextBlock">
                                             <Setter Property="Foreground" Value="{DynamicResource ThirdlyTextBrush}"/>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding Config.RuntimeValidationPassed}" Value="True">
                                                     <Setter Property="Foreground" Value="{DynamicResource StatusSuccessBrush}"/>
                                                 </DataTrigger>
                                                 <DataTrigger Binding="{Binding Config.RuntimeValidationPassed}" Value="False">
                                                     <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}"/>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </TextBlock.Style>
                                 </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                                    </StackPanel>
                                </hc:Card>

                            </StackPanel>
                        </hc:ScrollViewer>
                        </Grid>
                    </UserControl>
